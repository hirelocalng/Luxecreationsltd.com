# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_min_64_chars
JWT_EXPIRES_IN=7d

# Email (Nodemailer via Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=luxecreationsltd1@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Business email for inquiry notifications
ADMIN_EMAIL=luxecreationsltd1@gmail.com

# Cloudinary (for portfolio image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174

# Node environment
NODE_ENV=development

# Port
PORT=3001

# Admin panel default credentials (change after first login!)
ADMIN_EMAIL_INIT=admin@luxecreationsltd.com
ADMIN_PASSWORD_INIT=ChangeMe123!

# reCAPTCHA (optional — add site/secret keys to enable)
# RECAPTCHA_SECRET_KEY=your_secret_key
